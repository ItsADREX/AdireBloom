# ─── Paystack ───────────────────────────────────────────────────────────────
# Get these from https://dashboard.paystack.com/#/settings/developer
# Use test keys for development (sk_test_...) and live keys for production (sk_live_...)
PAYSTACK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY

JWT_SECRET=change_this_to_a_long_random_string_in_production

# ─── App ────────────────────────────────────────────────────────────────────
PORT=4000

# Example: http://localhost:5173,https://adirebloomtest.netlify.app
FRONTEND_URL=http://localhost:5173,https://adirebloomtest.netlify.app
